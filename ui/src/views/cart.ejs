<div class="container">
    <h1 style="margin-bottom: 0.5rem">Shopping Cart</h1>

    <% if (items && items.length > 0) { %>
        <div style="background-color: #e8f5e9; padding: 1.5rem; border-radius: 4px; margin-bottom: 2rem; font-size: 1.3rem; font-weight: bold;">
            Total: <%= (total / 100).toFixed(2) %> zł
        </div>

        <style>
            @media (max-width: 640px) {
                .cart-item-grid {
                    display: grid;
                    grid-template-columns: 1fr;
                    gap: 1rem;
                    align-items: flex-start;
                }
            }
            @media (min-width: 641px) {
                .cart-item-grid {
                    display: grid;
                    grid-template-columns: 1fr 2fr 1fr;
                    gap: 1rem;
                    align-items: center;
                }
            }
        </style>

        <div style="display: flex; flex-direction: column; gap: 1rem;">
            <% items.forEach(item => { %>
                <div style="border: 1px solid #ddd; padding: 1rem; border-radius: 4px; background-color: #fafafa;">
                    <div class="cart-item-grid">
                        <div>
                            <% if (item.product.imageUrl) { %>
                                <img src="<%= item.product.imageUrl %>" alt="<%= item.product.name %>" style="width: 100%; max-width: 120px; max-height: 120px; border-radius: 4px;">
                            <% } else { %>
                                <div style="width: 120px; height: 80px; background-color: #eee; display: flex; align-items: center; justify-content: center; color: #999; border-radius: 4px;">
                                    No Image
                                </div>
                            <% } %>
                        </div>

                        <div>
                            <h3><a href="/product/<%= item.product.id %>" style="color: #007bff; text-decoration: none;"><%= item.product.name %></a></h3>
                            <p style="color: #666; margin: 0.5rem 0;">Price: <%= (item.product.price / 100).toFixed(2) %> zł</p>
                            <p style="color: #666; margin: 0.5rem 0; font-weight: bold;">
                                Subtotal: <%= ((item.product.price * item.quantity) / 100).toFixed(2) %> zł
                            </p>
                        </div>

                        <div style="display: flex; flex-direction: column; gap: 0.5rem;">
                            <form action="/cart/update" method="POST" style="display: flex; gap: 0.5rem;">
                                <input type="hidden" name="productId" value="<%= item.product.id %>">
                                <input type="number" name="quantity" value="<%= item.quantity %>" min="1" style="width: 60px; padding: 0.5rem;">
                                <button type="submit" class="btn" style="flex: 1;">Update</button>
                            </form>

                            <form action="/cart/update" method="POST">
                                <input type="hidden" name="productId" value="<%= item.product.id %>">
                                <input type="hidden" name="quantity" value="0">
                                <button type="submit" class="btn btn-danger" style="width: 100%;">Remove</button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <div style="margin-top: 2rem;">
            <a href="/products" class="btn" style="margin: 2px;">Continue Shopping</a>
            <a href="/checkout" class="btn btn-success" style="margin: 2px;">Proceed to Checkout</a>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 2rem;">
            <p style="color: #999; font-size: 1.1rem;">Your cart is empty</p>
            <a href="/products" class="btn">Start Shopping</a>
        </div>
    <% } %>
</div>
