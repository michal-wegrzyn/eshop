<div class="container">
    <h1 style="margin-bottom: 0.5rem">Order Summary</h1>

    <% if (typeof checkoutError !== 'undefined' && checkoutError) { %>
        <div style="background-color: #f8d7da; border: 1px solid #f5c6cb; color: #721c24; padding: 1rem; border-radius: 4px; margin-bottom: 2rem;">
            <strong>Warning:</strong> <%= checkoutError %>
        </div>
        <% locals.checkoutError = undefined %>
    <% } %>

    <% if (items && items.length > 0) { %>
        <div style="background-color: #e8f5e9; padding: 1.5rem; border-radius: 4px; margin-bottom: 2rem; font-size: 1.3rem; font-weight: bold;">
            Total: <%= (total / 100).toFixed(2) %> zł
        </div>

        <style>
            @media (max-width: 640px) {
                .order-summary-item-grid {
                    display: grid;
                    grid-template-columns: 1fr;
                    gap: 1rem;
                    align-items: flex-start;
                }
            }
            @media (min-width: 641px) {
                .order-summary-item-grid {
                    display: grid;
                    grid-template-columns: 1fr 2fr 1fr;
                    gap: 1rem;
                    align-items: center;
                }
            }
        </style>

        <div style="display: flex; flex-direction: column; gap: 1rem; margin-bottom: 2rem;">
            <% items.forEach(item => { %>
                <div style="border: 1px solid #ddd; padding: 1rem; border-radius: 4px; background-color: #fafafa;">
                    <div class="order-summary-item-grid">
                        <div>
                            <% if (item.product.imageUrl) { %>
                                <img src="<%= item.product.imageUrl %>" alt="<%= item.product.name %>" style="width: 100%; max-width: 120px; max-height: 120px; border-radius: 4px;">
                            <% } else { %>
                                <div style="width: 120px; height: 80px; background-color: #eee; display: flex; align-items: center; justify-content: center; color: #999; border-radius: 4px;">
                                    No Image
                                </div>
                            <% } %>
                        </div>

                        <div>
                            <h3><a href="/product/<%= item.product.id %>" style="color: #007bff; text-decoration: none;"><%= item.product.name %></a></h3>
                            <p style="color: #666; margin: 0.5rem 0;">Price: <%= (item.product.price / 100).toFixed(2) %> zł</p>
                            <p style="color: #666; margin: 0.5rem 0;">Quantity: <%= item.quantity %></p>
                            <p style="color: #666; margin: 0.5rem 0; font-weight: bold;">
                                Subtotal: <%= ((item.product.price * item.quantity) / 100).toFixed(2) %> zł
                            </p>
                        </div>

                        <div>
                            <a href="/product/<%= item.product.id %>" class="btn">View Product</a>
                        </div>
                    </div>
                </div>
            <% }); %>
        </div>

        <div style="margin-bottom: 2rem;">
            <h3>Order Message (Optional)</h3>
            <form action="/order/create" method="POST">
                <div style="margin-bottom: 1rem;">
                    <textarea name="message" placeholder="Add a message to your order..." style="width: 100%; padding: 1rem; min-height: 100px; border: 1px solid #ddd; border-radius: 4px;"></textarea>
                </div>

                <input type="hidden" name="versionsHash" value="<%= versionsHash %>">
                
                <style>
                    @media (max-width: 480px) {
                        .order-summary-buttons {
                            display: flex;
                            flex-direction: column;
                            gap: 1rem;
                        }
                        .order-summary-buttons .btn {
                            width: 100%;
                        }
                    }
                    @media (min-width: 481px) {
                        .order-summary-buttons {
                            display: flex;
                            gap: 1rem;
                        }
                    }
                </style>
                
                <div class="order-summary-buttons">
                    <a href="/cart" class="btn" style="background-color: #6c757d; display: flex; align-items: center; justify-content: center;">Back to Cart</a>
                    <button type="submit" class="btn btn-success" style="flex: 1; font-size: 1rem;">Place Order</button>
                </div>
            </form>
        </div>
    <% } else { %>
        <div style="text-align: center; padding: 2rem;">
            <p style="color: #999; font-size: 1.1rem;">Your cart is empty</p>
            <a href="/products" class="btn">Start Shopping</a>
        </div>
    <% } %>
</div>
