<div class="container">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
        <h1>Products</h1>
        <% if (isManager) { %>
            <button onclick="document.getElementById('addProductForm').style.display='block'" class="btn btn-success">+ Add Product</button>
        <% } %>
    </div>

    <% if (isManager) { %>
        <div id="addProductForm" style="display: none; border: 1px solid #ddd; padding: 1rem; margin-bottom: 2rem; border-radius: 4px; background-color: #f9f9f9;">
            <h3>Add New Product</h3>
            <form action="/products/new" method="POST">
                <div style="margin-bottom: 1rem;">
                    <label for="newName">Name:</label>
                    <input type="text" id="newName" name="name" required style="width: 100%; padding: 0.5rem;">
                </div>
                <div style="margin-bottom: 1rem;">
                    <label for="newPrice">Price (zł):</label>
                    <input type="number" id="newPrice" name="price" step="0.01" required style="width: 100%; padding: 0.5rem;">
                </div>
                <div style="margin-bottom: 1rem;">
                    <label for="newDescription">Description:</label>
                    <textarea id="newDescription" name="description" style="width: 100%; padding: 0.5rem; min-height: 100px;"></textarea>
                </div>
                <div style="margin-bottom: 1rem;">
                    <label for="newImageUrl">Image URL:</label>
                    <input type="text" id="newImageUrl" name="imageUrl" style="width: 100%; padding: 0.5rem;">
                </div>
                <div style="display: flex; gap: 0.5rem;">
                    <button type="submit" class="btn btn-success">Create</button>
                    <button type="button" onclick="document.getElementById('addProductForm').style.display='none'" class="btn" style="background-color: #6c757d;">Cancel</button>
                </div>
            </form>
        </div>
    <% } %>

    <% if (searchQuery) { %>
        <p style="margin-bottom: 1rem; color: #666;">Search results for: <strong><%= searchQuery %></strong></p>
    <% } %>

    <% if (products && products.length > 0) { %>
        <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem;">
            <% products.forEach(product => { %>
                <div style="border: 1px solid #ddd; padding: 1rem; margin: 1rem 0; border-radius: 4px; background-color: #fafafa;">
                    <% if (product.imageUrl) { %>
                        <img src="<%= product.imageUrl %>" alt="<%= product.name %>" style="width: 100%; max-width: 250px; max-height: 250px; margin-bottom: 1rem;">
                    <% } else { %>
                        <div style="width: 250px; height: 150px; background-color: #eee; display: flex; align-items: center; justify-content: center; color: #999; margin-bottom: 1rem;">
                            No Image
                        </div>
                    <% } %>
                    
                    <h3><%= product.name %></h3>
                    
                    <p style="color: #666; margin: 0.5rem 0; max-height: 3.5em; overflow: hidden; text-overflow: ellipsis;">
                        <%= product.description || 'No description' %>
                    </p>
                    
                    <p style="font-size: 1.2rem; color: #28a745; margin: 0.5rem 0; font-weight: bold;">
                        <%= (product.price / 100).toFixed(2) %> zł
                    </p>

                    <div style="display: flex; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap;">
                        <a href="/product/<%= product.id %>" class="btn">View Details</a>

                        <form action="/cart/update" method="POST" style="display: flex; gap: 0.5rem;">
                            <input type="hidden" name="productId" value="<%= product.id %>">
                            <input type="number" name="quantity" value="<% if (cartMap && cartMap.has(product.id)) { %><%= cartMap.get(product.id) %><% } else { %>1<% } %>" min="1" style="width: 50px; padding: 0.5rem;">
                            <button type="submit" class="btn btn-success">Add to Cart</button>
                        </form>

                        <% if (cartMap && cartMap.has(product.id)) { %>
                            <form action="/cart/update" method="POST" style="display: inline;">
                                <input type="hidden" name="productId" value="<%= product.id %>">
                                <input type="hidden" name="quantity" value="0">
                                <button type="submit" class="btn btn-danger">Remove from cart</button>
                            </form>
                        <% } %>

                        <% if (isManager) { %>
                            <form action="/product/<%= product.id %>/delete" method="POST" style="display: inline;">
                                <button type="submit" class="btn btn-danger" onclick="return confirm('Delete this product?')">Delete product</button>
                            </form>
                        <% } %>
                    </div>
                </div>

            <% }); %>
        </div>
    <% } else { %>
        <p style="text-align: center; color: #999;">No products found.</p>
    <% } %>
</div>
